{
  "name": "Cobalt2",
  "base": "vs-dark",
  "inherit": true,
  "rules": [
    { "token": "", "foreground": "e1efff" },
    { "token": "comment", "foreground": "0088ff", "fontStyle": "italic" },
    { "token": "comment.line", "foreground": "0088ff", "fontStyle": "italic" },
    { "token": "comment.block", "foreground": "0088ff", "fontStyle": "italic" },
    { "token": "keyword", "foreground": "ff9d00", "fontStyle": "bold" },
    { "token": "keyword.control", "foreground": "ff9d00", "fontStyle": "bold" },
    { "token": "keyword.operator", "foreground": "ff9d00" },
    { "token": "storage", "foreground": "ff9d00", "fontStyle": "bold" },
    { "token": "storage.type", "foreground": "ff9d00", "fontStyle": "bold" },
    { "token": "storage.modifier", "foreground": "ff9d00" },
    { "token": "string", "foreground": "3ad900" },
    { "token": "string.quoted", "foreground": "3ad900" },
    { "token": "string.template", "foreground": "3ad900" },
    { "token": "string.interpolated", "foreground": "2affdf" },
    { "token": "constant", "foreground": "ff628c" },
    { "token": "constant.numeric", "foreground": "ff628c" },
    { "token": "constant.language", "foreground": "ff9d00" },
    { "token": "constant.character", "foreground": "ff628c" },
    { "token": "variable", "foreground": "cccccc" },
    { "token": "variable.language", "foreground": "ff628c" },
    { "token": "variable.parameter", "foreground": "ffee80" },
    { "token": "variable.other", "foreground": "cccccc" },
    { "token": "entity.name.function", "foreground": "ffc600" },
    { "token": "entity.name.class", "foreground": "80ffbb" },
    { "token": "entity.name.type", "foreground": "80ffbb" },
    { "token": "entity.name.tag", "foreground": "9effff" },
    { "token": "entity.other.attribute-name", "foreground": "ffc600" },
    { "token": "support.function", "foreground": "ffc600" },
    { "token": "support.class", "foreground": "80ffbb" },
    { "token": "support.type", "foreground": "9effff" },
    { "token": "support.constant", "foreground": "9effff" },
    { "token": "support.variable", "foreground": "cccccc" },
    { "token": "meta.function-call", "foreground": "ffc600" },
    { "token": "meta.tag", "foreground": "9effff" },
    { "token": "invalid", "foreground": "ffffff", "background": "ff628c" },
    { "token": "invalid.deprecated", "foreground": "ffffff", "background": "96a7b4" },
    { "token": "punctuation", "foreground": "e1efff" },
    { "token": "delimiter", "foreground": "e1efff" },
    { "token": "type", "foreground": "80ffbb" },
    { "token": "annotation", "foreground": "ff9d00" }
  ],
  "colors": {
    "editor.background": "#193549",
    "editor.foreground": "#e1efff",
    "editor.selectionBackground": "#0d3a5888",
    "editor.selectionHighlightBackground": "#0d3a5866",
    "editor.inactiveSelectionBackground": "#0d3a5855",
    "editor.lineHighlightBackground": "#0d3a58",
    "editor.lineHighlightBorder": "#00000000",
    "editorCursor.foreground": "#ffc600",
    "editorWhitespace.foreground": "#35434d",
    "editorIndentGuide.background": "#35434d",
    "editorIndentGuide.activeBackground": "#0088ff55",
    "editorLineNumber.foreground": "#35434d",
    "editorLineNumber.activeForeground": "#ffc600",
    "editorBracketMatch.background": "#0088ff33",
    "editorBracketMatch.border": "#ffc600",
    "editorGutter.background": "#15232d",
    "editorError.foreground": "#ff628c",
    "editorWarning.foreground": "#ff9d00",
    "editorInfo.foreground": "#2affdf",
    "editorHint.foreground": "#80ffbb",
    "editorOverviewRuler.errorForeground": "#ff628c",
    "editorOverviewRuler.warningForeground": "#ff9d00",
    "editorSuggestWidget.background": "#0d3a58",
    "editorSuggestWidget.border": "#35434d",
    "editorSuggestWidget.foreground": "#e1efff",
    "editorSuggestWidget.selectedBackground": "#0088ff33",
    "editorSuggestWidget.highlightForeground": "#ffc600",
    "editorHoverWidget.background": "#0d3a58",
    "editorHoverWidget.border": "#35434d",
    "scrollbarSlider.background": "#35434d88",
    "scrollbarSlider.hoverBackground": "#35434dcc",
    "scrollbarSlider.activeBackground": "#0088ffcc",
    "focusBorder": "#ffc600",
    "foreground": "#e1efff",
    "widget.shadow": "#00000066",
    "selection.background": "#0d3a58"
  },
  "custom": {
    "primary.background": "#ffc600",
    "primary.hoverBackground": "#ffd340",
    "primary.activeBackground": "#e6b200",
    "primary.textColor": "#193549",
    "secondary.background": "#193549",
    "secondary.border": "#0088ff",
    "secondary.hoverBorder": "#2affdf",
    "secondary.activeBorder": "#0066cc",
    "secondary.textColor": "#e1efff",
    "default.background": "#193549",
    "default.border": "#35434d",
    "default.hoverBorder": "#0088ff",
    "default.activeBorder": "#35434d",
    "default.textColor": "#e1efff",
    "theme.isLight": false
  }
}
